{
  "family": "devops-pro-task",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "app",
      #"image": "205930609978.dkr.ecr.us-east-1.amazonaws.com/devops-pro-app:latest",
      "image": "IMAGE_URI_PLACEHOLDER"
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 0
        }
      ]
    }
  ],
  "requiresCompatibilities": ["EC2"],
  "cpu": "256",
  "memory": "512"
}
