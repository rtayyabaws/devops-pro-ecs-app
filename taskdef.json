{
  "family": "devops-pro-task",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<<IMAGE1_NAME>>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 0
        }
      ]
    }
  ],
  "requiresCompatibilities": ["EC2"],
  "cpu": "256",
  "memory": "512"
}
